[Unit]
Description=TerraCast - Satellite Image Processing Service
After=network.target

[Service]
Type=simple
User=root
WorkingDirectory=%PROJECT_DIR%
ExecStart=%VENV_DIR%/bin/python %PROJECT_DIR%/terracast.py
StandardOutput=journal
StandardError=journal
SyslogIdentifier=terracast
Restart=always
RestartSec=10

[Install]
WantedBy=multi-user.target